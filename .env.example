# ---- HTTP / SSE ----
HOST=0.0.0.0
PORT=8931

# ---- 持久化身份核心配置 ----
# 用户数据目录（cookies / storage / 浏览历史落盘的地方）
USER_DATA_DIR=./user-data

# 是否使用本机 Chrome（推荐 true，channel:'chrome' 会自动定位）
USE_LOCAL_CHROME=true

# 启动时是否自动养号
WARMUP_ON_START=true

# 养号窗口可见？(true=无头, false=显示窗口便于手动救援人机校验)
WARMUP_HEADLESS=false

# 抓取时窗口可见？(true=无头跑得快, false=显示窗口便于观察)
SERVING_HEADLESS=false

# 维护"心跳访问"频率（毫秒，默认 30 分钟）
MAINTENANCE_INTERVAL_MS=1800000

# ---- 网络 ----
# 代理（可选；本机 IP 能正常访问 walmart.com 就不用配）
# PROXY=http://user:pass@host:port

# ---- HTTP / SSE ----
HOST=0.0.0.0
PORT=8931

# ---- 反爬模式 ----
# cdp        = 接管你手动启动的 Chrome（推荐，绕 PX 最强）
# persistent = Playwright 自己 launch（v2，已被识破）
MODE=cdp

# CDP 模式：Chrome 调试端口
CDP_URL=http://localhost:9222
CDP_AUTO_RECONNECT_MS=5000

# ---- persistent 模式专用（仅 MODE=persistent 时生效） ----
USER_DATA_DIR=./user-data
USE_LOCAL_CHROME=true
WARMUP_ON_START=true
WARMUP_HEADLESS=false
SERVING_HEADLESS=false
MAINTENANCE_INTERVAL_MS=1800000

# ---- 网络 ----
# PROXY=http://user:pass@host:port
